# better-auth declares @sveltejs/kit as an optional peer, which transitively
# demands vite@8 while the Nuxt 4 stack pins vite@7. hop uses better-auth's
# Drizzle adapter, not the Svelte adapter, so this peer conflict is spurious.
# legacy-peer-deps keeps `npm install` deterministic without a manual flag.
legacy-peer-deps=true
