{
  "name": "somerset-hop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt preview",
    "prepare": "nuxt prepare",
    "db:generate:auth": "node scripts/with-env.mjs auth generate --config ./server/auth/config.ts --output ./server/db/schema/better-auth.generated.ts --yes",
    "db:generate": "npm run db:generate:auth && node scripts/with-env.mjs drizzle-kit generate",
    "db:migrate": "node scripts/with-env.mjs drizzle-kit migrate",
    "db:setup": "npm run db:generate && npm run db:migrate",
    "test:unit": "vitest run",
    "test:db:smoke": "node scripts/with-env.mjs vitest run tests/db/migration-smoke.test.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@better-auth/sso": "^1.6.11",
    "@nuxt/ui": "^4.7.1",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.5",
    "postgres": "^3.4.9",
    "reka-ui": "^2.9.7",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.28"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.107",
    "@types/node": "^22.10.2",
    "auth": "^1.6.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
